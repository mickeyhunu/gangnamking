<%- include('partials/head', { title: pageTitle, description: metaDescription, seoKeywords, jsonLd }) %>
  <section class="section" id="areas">
    <div class="container">
      <div class="section__header">
        <div>
          <h2 class="section__title"><%= t.areas && t.areas.title ? t.areas.title : '' %></h2>
          <p class="section__subtitle"><%= t.areas && t.areas.subtitle ? t.areas.subtitle : '' %></p>
        </div>
      </div>
      <div class="shop-groups">
        <% (shopsByCategory || []).forEach(function(group) { %>
          <section class="shop-category" data-category-section="<%= group.category %>">
            <header class="shop-category__header">
              <h3 class="shop-category__title"><%= group.category %></h3>
            </header>
            <div class="shop-grid" data-grid data-category-group="<%= group.category %>">
              <% group.shops.forEach(function(shop) { %>
                <a
                  class="shop-card"
                  href="/shops/<%= shop.id %>"
                  data-region="<%= shop.region %>"
                  data-district="<%= shop.district %>"
                  data-category="<%= shop.category %>"
                  data-area-group="<%= shop.areaGroup %>"
                >
                  <div class="shop-card__image">
                    <% if (shop.image) { %>
                      <img src="<%= shop.image %>" alt="<%= shop.imageAlt || shop.name %>" />
                    <% } %>
                  </div>
                  <div class="shop-card__body">
                    <div class="shop-card__info">
                      <span class="shop-card__meta"><%= shop.region %> · <%= shop.district %></span>
                      <h3 class="shop-card__name"><%= shop.name %></h3>
                      <div class="shop-card__meta-row">
                        <span class="shop-card__category"><%= shop.category %></span>
                        <span class="shop-card__link">
                          <%= t.shop && t.shop.viewDetails ? t.shop.viewDetails : '' %>
                        </span>
                      </div>
                    </div>
                  </div>
                </a>
              <% }) %>
            </div>
          </section>
        <% }) %>
      </div>
    </div>
  </section>

  <% if (seoContent) { %>
    <section class="section seo-overview" aria-labelledby="seo-overview-title">
      <div class="container">
        <div class="seo-overview__container">
          <p class="seo-overview__eyebrow"><%= (t.meta && t.meta.siteName) || '룸빵1번지' %></p>
          <h1 class="seo-overview__title" id="seo-overview-title"><%= seoContent.heading %></h1>
          <p class="seo-overview__summary"><%= seoContent.summary %></p>
          <% if (seoContent.keywordHighlights && seoContent.keywordHighlights.length) { %>
            <ul class="seo-overview__keywords" aria-label="추천 검색 키워드">
              <% seoContent.keywordHighlights.forEach(function(keyword) { %>
                <li><%= keyword %></li>
              <% }) %>
            </ul>
          <% } %>
        </div>
        <div class="seo-overview__promo-container" aria-label="미드나잇맨즈 유흥 커뮤니티 홍보 영역">
          <div class="seo-overview__promo-copy">
            <a class="seo-overview__community-link" href="https://nightmens.com/community" target="_blank" rel="noopener noreferrer">유흥 커뮤니티 소통 사이트 미드나잇맨즈</a>
            <p class="seo-overview__community-description">
              미드나잇맨즈는 유흥 관련 소통을 위한 커뮤니티 사이트로, 가게별 현장 상황과 여러 업체의 금액 비교, 실제 후기를 확인할 수 있는 콘텐츠를 제공합니다. 유흥 커뮤니티를 메인 유입 키워드로 삼아 강남하퍼, 강남 달토, 달리는토끼, 유앤미, 쩜오 등 주요 검색 키워드 정보를 함께 다룹니다.
            </p>
          </div>
          <a
            class="seo-overview__promo"
            href="https://nightmens.com/community"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="미드나잇맨즈 홍보 페이지로 이동"
          >
            <img
              class="seo-overview__promo-image"
              src="/images/promo/midnightmens.png"
              alt="미드나잇맨즈 유흥 커뮤니티 홍보 배너"
              loading="lazy"
            />
          </a>
        </div>
      </div>
    </section>
  <% } %>

  <script id="region-district-data" type="application/json">
    <%- JSON.stringify(districtMap) %>
  </script>
<%- include('partials/footer') %>
