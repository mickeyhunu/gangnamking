<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= pageTitle %></title>
    <style>
      body { font-family: 'Noto Sans KR', sans-serif; margin: 0; background: #f6f8fb; color: #1f2937; }
      main { max-width: 1120px; margin: 0 auto; padding: 24px 16px 40px; }
      .admin-layout { display: grid; gap: 16px; }
      .admin-panel { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 16px; }
      .admin-stat-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(160px,1fr)); gap: 10px; }
      .admin-stat-card { border: 1px solid #e5e7eb; border-radius: 10px; padding: 12px; background:#fafafa; }
      .admin-stat-card strong { display: block; font-size: 22px; margin-top: 4px; }
      .admin-stat-card small { color: #64748b; }
      .admin-panel-header { display:flex; justify-content:space-between; gap:12px; align-items:center; margin-bottom: 12px; }
      table { width:100%; border-collapse: collapse; font-size: 14px; }
      th, td { border-bottom:1px solid #e5e7eb; padding:8px; text-align:left; }
      .chart-row { display:grid; grid-template-columns: 120px 1fr 240px; gap: 8px; align-items:center; margin: 8px 0; }
      .bar-track { background:#eef2ff; border-radius:8px; padding: 6px; }
      .bar-group { display:grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
      .bar { height: 9px; border-radius: 999px; background:#dbeafe; overflow:hidden; }
      .bar > span { display:block; height:100%; min-width:8%; }
      .bar--v > span { background:#2563eb; }
      .bar--vw > span { background:#0ea5e9; }
      .bar--p > span { background:#16a34a; }
      .bar--c > span { background:#f59e0b; }
      .chart-meta { color: #475569; font-size: 13px; }
    </style>
  </head>
  <body>
    <main>
      <h1>관리자 통계</h1>
      <div class="admin-layout">
        <section class="admin-panel">
          <h2>전체 현황</h2>
          <div class="admin-stat-grid">
            <article class="admin-stat-card"><span>전체 방문자수</span><strong><%= totals.visitors %></strong><small>오늘 <%= today.visitors %>명</small></article>
            <article class="admin-stat-card"><span>전체 접속량</span><strong><%= totals.views %></strong><small>오늘 <%= today.views %>회</small></article>
            <article class="admin-stat-card"><span>전체 게시글</span><strong><%= totals.posts %></strong><small>오늘 <%= today.posts %>건</small></article>
            <article class="admin-stat-card"><span>전체 댓글</span><strong><%= totals.comments %></strong><small>오늘 <%= today.comments %>건</small></article>
            <article class="admin-stat-card"><span>전체 회원</span><strong><%= totals.members %></strong></article>
          </div>
        </section>

        <section class="admin-panel">
          <div class="admin-panel-header">
            <h2>게시판별 게시글 수</h2>
          </div>
          <table aria-label="게시판별 게시글 수">
            <thead><tr><th>게시판</th><th>게시글 수</th></tr></thead>
            <tbody>
              <% boardPostCounts.forEach((item) => { %>
                <tr><td><%= item.boardName %></td><td><%= item.posts %></td></tr>
              <% }) %>
            </tbody>
          </table>
        </section>

        <section class="admin-panel">
          <div class="admin-panel-header">
            <div>
              <p id="stats-period-caption"><%= periodCaption %></p>
              <h2 id="stats-period-title"><%= periodTitle %></h2>
            </div>
            <select id="stats-period-select" onchange="location.href='?period=' + this.value">
              <option value="daily" <%= selectedPeriod === 'daily' ? 'selected' : '' %>>일별</option>
              <option value="weekly" <%= selectedPeriod === 'weekly' ? 'selected' : '' %>>주별</option>
              <option value="monthly" <%= selectedPeriod === 'monthly' ? 'selected' : '' %>>월별</option>
              <option value="yearly" <%= selectedPeriod === 'yearly' ? 'selected' : '' %>>연도별</option>
            </select>
          </div>

          <div id="stats-chart">
            <% rows.forEach((row) => { %>
              <div class="chart-row">
                <strong><%= row.label %></strong>
                <div class="bar-track">
                  <div class="bar-group">
                    <div class="bar bar--v" title="방문자수 <%= row.visitors %>"><span style="width:<%= Math.max(8, Math.round((row.visitors / maxValue) * 100)) %>%"></span></div>
                    <div class="bar bar--vw" title="접속량 <%= row.views %>"><span style="width:<%= Math.max(8, Math.round((row.views / maxValue) * 100)) %>%"></span></div>
                    <div class="bar bar--p" title="게시글 <%= row.posts %>"><span style="width:<%= Math.max(8, Math.round((row.posts / maxValue) * 100)) %>%"></span></div>
                    <div class="bar bar--c" title="댓글 <%= row.comments %>"><span style="width:<%= Math.max(8, Math.round((row.comments / maxValue) * 100)) %>%"></span></div>
                  </div>
                </div>
                <div class="chart-meta">방문 <%= row.visitors %> · 접속 <%= row.views %> · 글 <%= row.posts %> · 댓글 <%= row.comments %></div>
              </div>
            <% }) %>
          </div>

          <h3>최근 통계 테이블</h3>
          <table aria-label="최근 통계 테이블">
            <thead><tr><th>기간</th><th>방문자</th><th>접속량</th><th>게시글</th><th>댓글</th></tr></thead>
            <tbody>
              <% rows.forEach((row) => { %>
                <tr>
                  <td><%= row.label %></td>
                  <td><%= row.visitors %></td>
                  <td><%= row.views %></td>
                  <td><%= row.posts %></td>
                  <td><%= row.comments %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </section>
      </div>
    </main>
  </body>
</html>
